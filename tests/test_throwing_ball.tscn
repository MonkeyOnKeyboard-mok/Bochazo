[sub_resource type="GDScript" id="ResetScript"]
script/source = "extends Node

func _on_reset_button_pressed() -> void:
	#get_tree().reload_current_scene()
	if GameManager.p1_turns != 0 or GameManager.p2_turns != 0:
		GameManager.emit_signal(\"idle\")
		GameManager.spawn_bocha.emit()
"

